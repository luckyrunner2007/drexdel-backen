{
  "expo": {
    "name": "drexdelnative",
    "slug": "drexdel",
    "version": "1.0.0",
    "platforms": ["ios", "android", "web"],
    "web": {
      "bundler": "metro"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#7B2CBF"
    },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "com.drexdel.nativeapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7B2CBF"
      }
    },
    "ios": {
      "bundleIdentifier": "com.drexdel.nativeapp",
      "buildNumber": "1.0.0"
    }
  },
  "expo": {
    "scheme": "drexdel",
    "web": {
      "bundler": "metro"
    }
  }
}